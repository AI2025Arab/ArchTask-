# ArchTask Environment Variables
# Copy this file to .env and fill in the values before running.
# NEVER commit the actual .env file with real API keys.

# ─── ArchTask AI Keys (REQUIRED for AI features) ─────────────────────────────
# Groq API key for voice-to-text (Whisper STT)
# Get yours at: https://console.groq.com
GROQ_API_KEY=

# Google Gemini API key for task generation, BOQ, and suggestions
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Vikunja Core (optional overrides) ───────────────────────────────────────
# VIKUNJA_SERVICE_JWTSECRET=  # Auto-generated if empty
# VIKUNJA_SERVICE_FRONTENDURL=http://localhost:80
